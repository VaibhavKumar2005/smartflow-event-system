# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Server
PORT=3000
NODE_ENV=development

# Security — set this to your frontend origin in production
# Example: ALLOWED_ORIGIN=https://your-app.vercel.app
# Leave unset or * for local development (open CORS)
ALLOWED_ORIGIN=*

# Rate limiting — max requests per IP per 60 seconds on /api/*
RATE_LIMIT_MAX=30
